APP_NAME="Klinik Dokterku"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://klinik.yourdomain.com
APP_LOCALE=id
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prb_klinik
DB_USERNAME=                      # jangan pakai root di production
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database

# WA Local Service secret (generate: openssl rand -hex 32)
WA_SECRET=

FILESYSTEM_DISK=local
MAIL_MAILER=log
